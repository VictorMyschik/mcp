# Lite MCP profile for IDEs with a low tool-count limit (e.g. PHPStorm GitHub Copilot: 128).
# Copy to .env.local or pass via `npm run start:lite`.
#
# Keeps SQL + Swagger meta/auth/call tools (~17). Drops api_* generation, browser, and vitour.

SWAGGER_GENERATED_API_TOOLS_ENABLED=false
BROWSER_TOOLS_ENABLED=false
VITOUR_TOOLS_ENABLED=false

# Reuse the same DB/Swagger/auth values as your main .env:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=outvento
# DB_PASSWORD=outvento
# DB_NAME=outvento
# SWAGGER_URL=https://api.outvento.test/docs?api-docs.json
# API_TLS_INSECURE_SKIP_VERIFY=true

# Monitoring (enabled in lite when ../outvento + SSH key exist):
# OUTVENTO_ROOT=/home/allximik/ide/outvento
# MONITORING_SSH_KEY=~/.ssh/outvento_server
