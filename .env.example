DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=secret
DB_NAME=app
SWAGGER_URL=http://localhost/api/docs.json
AUTH_LOGIN_PATH=/api/v1/login
AUTH_LOGIN_METHOD=post
AUTH_USERNAME_FIELD=login
AUTH_PASSWORD_FIELD=password
AUTH_TOKEN_FIELD_PATH=content.accessToken
AUTH_REFRESH_TOKEN_FIELD_PATH=content.refreshToken
AUTH_TOKEN_TYPE_FIELD_PATH=content.tokenType
AUTH_DEFAULT_TOKEN_TYPE=Bearer
AUTH_AUTO_LOGIN=true
API_REQUEST_TIMEOUT_MS=15000
API_RETRY_ON_UNAUTHORIZED=true
BROWSER_TOOLS_ENABLED=true
BROWSER_HEADLESS_DEFAULT=true
BROWSER_SESSION_TTL_MS=600000
BROWSER_CLEANUP_INTERVAL_MS=60000
BROWSER_NAVIGATION_TIMEOUT_MS=30000
BROWSER_ACTION_TIMEOUT_MS=30000
BROWSER_MAX_CONSOLE_ENTRIES=200
BROWSER_MAX_NETWORK_ERRORS=200
FRONTEND_AUTH_STORAGE_KEY=auth
BROWSER_ARTIFACTS_DIR=artifacts/browser
